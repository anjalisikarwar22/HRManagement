@model HRManagement.MVC.Models.Job.CreateJobVM
<section class="panel form-panel">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="form-grid">
            <label class="form-field">
                <span asp-for="JobId"></span>
                <input class="form-control" asp-for="JobId" />
                <span asp-validation-for="JobId" class="text-danger"></span>
            </label>
            <label class="form-field">
                <span asp-for="JobTitle"></span>
                <input class="form-control" asp-for="JobTitle" />
                <span asp-validation-for="JobTitle" class="text-danger"></span>
            </label>
            <label class="form-field">
                <span asp-for="MinSalary"></span>
                <input class="form-control" asp-for="MinSalary" />
                <span asp-validation-for="MinSalary" class="text-danger"></span>
            </label>
            <label class="form-field">
                <span asp-for="MaxSalary"></span>
                <input class="form-control" asp-for="MaxSalary" />
                <span asp-validation-for="MaxSalary" class="text-danger"></span>
            </label>
        </div>
        <div class="form-actions">
            <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
            <button class="btn btn-primary" type="submit">Save Job</button>
        </div>
    </form>
</section>
